{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": true,
    "downlevelIteration": true,
    "importHelpers": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@lib/api": ["src/lib/api"],
      "@lib/auth": ["src/lib/auth"],
      "@lib/db": ["src/lib/db"],
      "@lib/ui": ["src/lib/ui"],
      "@lib/assertions": ["src/lib/assertions"],
      "@lib/factories": ["src/lib/factories"],
      "@lib/config": ["src/lib/config"],
      "@lib/types": ["src/lib/types"],
      "@fixtures/*": ["src/fixtures/*"],
      "@features/*": ["tests/features/*"]
    },
    "strict": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["node_modules/@types"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "playwright.config.ts", "global-setup.ts", "global-teardown.ts"],
  "exclude": ["node_modules", "dist"]
}
